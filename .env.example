# ============================================
# ForecastWell Pro - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Flask Configuration
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY
FLASK_ENV=development
PORT=5000

# ============================================
# Weather API Keys
# ============================================

# OpenWeatherMap API (FREE tier - 1,000 calls/day)
# Sign up: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key-here

# IMD API (Optional - for India Meteorological Department data)
IMD_API_KEY=

# ============================================
# Notification Configuration (All Optional)
# ============================================

# Email Alerts (SMTP)
EMAIL_ENABLED=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# SMS Alerts via Twilio
# Sign up: https://www.twilio.com/
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890
SMS_RECIPIENTS=+919876543210,+919876543211

# WhatsApp Alerts via Twilio
# Setup: https://www.twilio.com/whatsapp
WHATSAPP_ENABLED=false
WHATSAPP_FROM_NUMBER=whatsapp:+14155238886
WHATSAPP_RECIPIENTS=whatsapp:+919876543210

# ============================================
# Supabase Database (Optional)
# ============================================
# Sign up: https://supabase.com
# Get credentials: Dashboard → Project Settings → API
# Run supabase_schema.sql in the SQL Editor to create tables
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-key
