{
  "name": "forecastwell-demo-video",
  "version": "1.0.0",
  "description": "ForecastWell Dashboard – 55s product demo video built with Remotion",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render ForecastWellDemo out/forecastwell-demo.mp4",
    "render": "remotion render ForecastWellDemo out/forecastwell-demo.mp4 --codec=h264",
    "render:gif": "remotion render ForecastWellDemo out/forecastwell-demo.gif --codec=gif",
    "render:webm": "remotion render ForecastWellDemo out/forecastwell-demo.webm --codec=vp8",
    "still": "remotion still ForecastWellDemo --frame=0 out/thumbnail.png"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "remotion": "4.0.290"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.5"
  },
  "remotion": {
    "entryPoint": "./src/index.ts"
  }
}
